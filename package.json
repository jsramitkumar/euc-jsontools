{
  "name": "jsontools",
  "version": "1.0.0",
  "private": true,
  "description": "JSON Compare SaaS Platform - Production Grade",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "db:push": "pnpm --filter @jsontools/api db:push",
    "db:migrate": "pnpm --filter @jsontools/api db:migrate",
    "db:studio": "pnpm --filter @jsontools/api db:studio",
    "db:seed": "pnpm --filter @jsontools/api db:seed",
    "setup": "pnpm install && pnpm db:push && pnpm db:seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
