# ================================
# ENVIRONMENT CONFIGURATION
# Copy to apps/api/.env and apps/web/.env.local
# ================================

# ---- Database (remote hosted) ----
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<dbname>

# ---- Redis (remote hosted) ----
REDIS_URL=redis://:<password>@<host>:<port>

# ---- API ----
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# ---- Auth / JWT ----
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Frontend ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Server-side proxy target (used by Next.js rewrites — no NEXT_PUBLIC_ needed)
API_URL=http://localhost:4000
NEXTAUTH_SECRET=change-me-to-a-long-random-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ---- OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Razorpay ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Storage (local dev uses filesystem) ----
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage
# For production S3:
# STORAGE_DRIVER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=

# ---- Rate Limiting ----
FREE_TIER_DAILY_LIMIT=10

# ---- Internal API Key (service-to-service) ----
INTERNAL_API_KEY=change-me-internal-service-key
